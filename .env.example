# Neon → Connection string → Pooled connection (PgBouncer)
DATABASE_URL=postgresql://user:password@ep-xxx-pooler.eu-central-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require
# Neon → Connection string → Direct connection (kein -pooler, für Migrationen)
DIRECT_URL=postgresql://user:password@ep-xxx.eu-central-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require
# Resend → Dashboard → API Keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
# Jita Admin → beliebiger sicherer String (z.B. openssl rand -hex 32)
ADMIN_SECRET=change-me
