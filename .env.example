# Neon → Connection string → Pooled connection (PgBouncer)
DATABASE_URL=postgresql://user:password@ep-xxx-pooler.eu-central-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require
# Neon → Connection string → Direct connection (no -pooler, used for migrations)
DIRECT_URL=postgresql://user:password@ep-xxx.eu-central-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require
# Resend → Dashboard → API Keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
# Jita admin area → any secure string (e.g. openssl rand -hex 32)
ADMIN_SECRET=change-me
# Public app URL (used for email links)
APP_URL=http://localhost:3000
# Sender address (must be a verified Resend domain in production; use onboarding@resend.dev for dev)
EMAIL_FROM=Jita Vereinsverwaltung <onboarding@resend.dev>
