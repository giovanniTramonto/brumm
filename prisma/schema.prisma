generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-1.0.x", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Club {
  id              String   @id @default(cuid())
  slug            String   @unique
  name            String
  adminEmail      String?
  membershipFee   Float?
  encryptedDsn    String?
  encryptedS3Config String?
  createdAt       DateTime @default(now())

  users             User[]
  sessions          Session[]
  invites           Invite[]
  documentTemplates DocumentTemplate[]
  managers          Manager[]
  team              Team[]
  documents         Document[]
  deviceSessions    DeviceSession[]
  clubISBJConfig    ClubISBJConfig?
}

model User {
  id        String       @id @default(cuid())
  clubId    String
  role      Role         @default(MEMBER)
  status    MemberStatus @default(REGISTERED)
  storageId String?

  isMemberManager         Boolean   @default(false)
  hasSubmittedDocuments   Boolean   @default(false)
  deactivatedAt           DateTime?

  createdAt DateTime @default(now())

  club            Club             @relation(fields: [clubId], references: [id])
  sessions        Session[]
  magicLinks      MagicLink[]
  invites         Invite[]
  memberDocuments MemberDocument[]
  deviceSessions  DeviceSession[]

  @@unique([storageId, clubId])
}

model Invite {
  id        String   @id @default(cuid())
  clubId    String
  userId    String
  token     String   @unique @default(cuid())
  expiresAt DateTime
  isUsed    Boolean  @default(false)
  createdAt DateTime @default(now())

  club Club @relation(fields: [clubId], references: [id])
  user User @relation(fields: [userId], references: [id])
}

model MagicLink {
  id                       String   @id @default(cuid())
  userId                   String
  token                    String   @unique @default(cuid())
  otpCode                  String?
  expiresAt                DateTime
  isUsed                   Boolean  @default(false)
  pendingPinHash           String?
  pendingDeviceTokenToDelete String?
  createdAt                DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  clubId    String
  token     String   @unique @default(cuid())
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
  club Club @relation(fields: [clubId], references: [id])
}

model DocumentTemplate {
  id           String           @id @default(cuid())
  clubId       String
  name         String
  ref          String
  order        Int              @default(0)
  documentType String?
  fileName     String?
  s3Key        String?
  createdAt    DateTime         @default(now())

  club        Club             @relation(fields: [clubId], references: [id])
  submissions MemberDocument[]

  @@unique([clubId, ref])
}

model Document {
  id        String   @id @default(cuid())
  clubId    String
  name      String
  order     Int      @default(0)
  type      String   @default("document")
  fileName  String?
  s3Key     String?
  url       String?
  createdAt DateTime @default(now())

  club Club @relation(fields: [clubId], references: [id])
}

model Manager {
  id              String   @id @default(cuid())
  clubId          String
  storageId       String
  isMemberManager Boolean  @default(false)
  createdAt       DateTime @default(now())

  club Club @relation(fields: [clubId], references: [id])

  @@unique([storageId, clubId])
}

model Team {
  id        String   @id @default(cuid())
  clubId    String
  storageId String
  createdAt DateTime @default(now())

  club Club @relation(fields: [clubId], references: [id])

  @@unique([storageId, clubId])
}

model MemberDocument {
  id         String    @id @default(cuid())
  memberId   String
  templateId String
  fileName   String?
  s3Key      String?
  uploadedAt DateTime  @default(now())
  readAt     DateTime?

  member   User             @relation(fields: [memberId], references: [id])
  template DocumentTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@unique([memberId, templateId])
}

model DeviceSession {
  id             String    @id @default(cuid())
  userId         String
  clubId         String
  deviceToken    String    @unique
  deviceId       String    @default("")
  displayName    String    @default("")
  pinHash        String
  failedAttempts Int       @default(0)
  lockedAt       DateTime?
  expiresAt      DateTime
  createdAt      DateTime  @default(now())

  user User @relation(fields: [userId], references: [id])
  club Club @relation(fields: [clubId], references: [id])

  @@index([deviceId, clubId])
}

enum Role {
  SUPERUSER
  TEAM
  MEMBER
  MANAGER
}

enum MemberStatus {
  PENDING_INVITE
  REGISTERED
  ACTIVE
  INACTIVE
  DEACTIVATED
}

model ClubISBJConfig {
  id                 String   @id @default(cuid())
  clubId             String   @unique
  host               String   @default("ds.traegerportal.isbj.verwalt-berlin.de")
  username           String
  traegerNummer      String
  einrichtungsNummer String
  encryptedApiKey    String
  encryptedCert      String
  encryptedCertPass  String
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  club Club @relation(fields: [clubId], references: [id])
}

model AuditLog {
  id        String        @id @default(cuid())
  clubId    String?
  event     String
  severity  AuditSeverity @default(INFO)
  ip        String?
  path      String?
  userId    String?
  metadata  Json?
  createdAt DateTime      @default(now())

  @@index([clubId, createdAt])
  @@index([createdAt])
}

enum AuditSeverity {
  INFO
  WARN
  ERROR
}
