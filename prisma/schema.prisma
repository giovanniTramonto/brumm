generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Club {
  id               String   @id @default(cuid())
  slug             String   @unique
  name             String
  storageType   Storage?
  storageConfig Json?
  oauthToken    Json?
  isSetupDone   Boolean  @default(false)
  createdAt        DateTime @default(now())

  users             User[]
  sessions          Session[]
  invites           Invite[]
  groups            Group[]
  documentTemplates DocumentTemplate[]
}

model Group {
  id        String   @id @default(cuid())
  clubId    String
  name      String
  email     String?
  createdAt DateTime @default(now())

  club Club @relation(fields: [clubId], references: [id])
}

model User {
  id        String  @id @default(cuid())
  clubId    String
  role      Role    @default(MEMBER)
  isActive  Boolean @default(false)
  storageId String?

  localData Json?

  createdAt DateTime @default(now())

  club            Club             @relation(fields: [clubId], references: [id])
  emails          UserEmail[]
  sessions        Session[]
  magicLinks      MagicLink[]
  invites         Invite[]
  memberDocuments MemberDocument[]

  @@unique([storageId, clubId])
}

model UserEmail {
  id        String   @id @default(cuid())
  userId    String
  email     String   @unique
  isPrimary Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

model Invite {
  id        String   @id @default(cuid())
  clubId    String
  userId    String
  token     String   @unique @default(cuid())
  expiresAt DateTime
  isUsed    Boolean  @default(false)
  createdAt DateTime @default(now())

  club Club @relation(fields: [clubId], references: [id])
  user User @relation(fields: [userId], references: [id])
}

model MagicLink {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique @default(cuid())
  expiresAt DateTime
  isUsed    Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  clubId    String
  token     String   @unique @default(cuid())
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
  club Club @relation(fields: [clubId], references: [id])
}

model DocumentTemplate {
  id            String           @id @default(cuid())
  clubId        String
  name          String
  ref           String
  order         Int              @default(0)
  documentType  String?
  driveFileId   String?
  driveFileName String?
  createdAt     DateTime         @default(now())

  club        Club             @relation(fields: [clubId], references: [id])
  submissions MemberDocument[]

  @@unique([clubId, ref])
}

model MemberDocument {
  id          String    @id @default(cuid())
  memberId    String
  templateId  String
  driveFileId String?
  filename    String?
  uploadedAt  DateTime  @default(now())
  readAt      DateTime?

  member   User             @relation(fields: [memberId], references: [id])
  template DocumentTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@unique([memberId, templateId])
}

enum Role {
  SUPERUSER
  TEAM
  MEMBER
}

enum Storage {
  GOOGLE_DRIVE
  S3
  R2
}
